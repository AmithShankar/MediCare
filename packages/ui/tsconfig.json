{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "paths": {
      "@medicare-pro/types": ["../types/src/index.ts"],
      "@medicare-pro/utils": ["../utils/src/index.ts"],
      "@medicare-pro/store": ["../store/src/index.ts"],
      "@medicare-pro/hooks": ["../hooks/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
