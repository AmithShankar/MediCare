{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@medicare-pro/types": ["../../packages/types/src/index.ts"],
      "@medicare-pro/utils": ["../../packages/utils/src/index.ts"],
      "@medicare-pro/ui": ["../../packages/ui/src/index.ts"],
      "@medicare-pro/store": ["../../packages/store/src/index.ts"],
      "@medicare-pro/hooks": ["../../packages/hooks/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
